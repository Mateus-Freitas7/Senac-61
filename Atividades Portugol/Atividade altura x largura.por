programa {
  funcao inicio() {
    
real altura
real largura 
real area

escreva("digite a altura em (metros): ")
leia (altura)

escreva("digite  a largura em (metros): ")
leia(largura)

area=altura*largura
escreva(" \nCalculo da base (altura x largura): ",area)

escreva ("\nA área total é: " ,area, " em metros quadrados")
















  }
}
