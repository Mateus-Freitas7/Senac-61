programa {
  funcao inicio() {
    
  real area
  real quantidade
  real porcentagem
  real areafinal

  escreva("\nQual a quantidade de piso a ser comprada:")
  leia(quantidade)


  escreva("\nA compra de piso tera que aumentar em :")
  leia(porcentagem)


  area=quantidade*porcentagem/100 //Quantidade de pisos da área a mais

  areafinal=area+quantidade

escreva("Quantidade total comprado será:",areafinal)















    
    
    
  }
}
