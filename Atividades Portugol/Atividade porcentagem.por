programa {
  funcao inicio() {
    real salario
    real aumento
    real salariofinal
   real valoraumentado

     escreva("Salário atual do funcionário:")
     leia(salario)

     escreva("Qual porcentagem de aumento:")
     leia(aumento)

valoraumentado=salario*aumento/100
salariofinal=valoraumentado+salario

escreva ("\n Salário anterior era:",salario)

 escreva ("\n Seu salário aumentou ",valoraumentado)
 
     escreva("\n Seu salário final:",salariofinal)








  }
}
