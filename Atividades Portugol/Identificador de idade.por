programa {
  funcao inicio() {
    
    inteiro x
inteiro pessoa,idade

    para (inteiro x=1;x<=200;x++){
      escreva( "\n\n-Pessoa " , x , "\nQual a sua idade?")
      leia (idade)
      se(idade>=18){
escreva("\nMaior de idade")
      }
      
    senao{
      escreva("\nMenor de idade")
    }

    
      }

    }
     
  }
}
