programa {
  funcao inicio() {
    
inteiro senha=123, usuario   = 5, senhausuario,usariousuario


escreva("\nDigite o número do usuário:")
leia(usariousuario)

escreva("\nDigite a senha do usuário:")
leia(senhausuario)

se(senha==senhausuario & usuario==usariousuario){
escreva("Acesso liberado")
}

senao{
  escreva("Acesso Negado")
}

  }
}
